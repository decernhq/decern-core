{
  "name": "decern",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/vercel-prebuild.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync-plan": "tsx scripts/sync-plan-from-stripe.ts",
    "qa:seed": "tsx decern-gate-demo/qa-demo/seed-prereqs.ts",
    "qa:run": "tsx decern-gate-demo/qa-demo/run-all-qa.ts",
    "qa:all": "npm run qa:seed && npm run qa:run",
    "qa:validate": "bash decern-gate-demo/qa-demo/run-validate.sh",
    "qa:judge": "bash decern-gate-demo/qa-demo/run-judge.sh"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "clsx": "^2.1.1",
    "next": "14.2.21",
    "next-intl": "^4.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.20",
    "decern-gate": "^0.1.11",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.21",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/decernorg/decern"
  }
}
