# Supabase
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Webhook Stripe: segreto condiviso con il DB (NON usare la service role).
# Dopo la migration 00014, in Supabase SQL Editor: select secret from app_webhook_secret;
# Copia il valore qui (una sola volta, puoi usare il SQL Editor con la service role per leggerlo).
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-from-db

# Stripe
# Chiavi: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Price ID (NON Product ID): Stripe Dashboard → Prodotti → Crea prodotto "Pro" → Aggiungi prezzo (es. 19€/mese) → Copia l'ID del prezzo (inizia con price_)
STRIPE_PRO_PRICE_ID=price_...
# Opzionale per piano Ultra (49€/mese)
# STRIPE_ULTRA_PRICE_ID=price_...

# App URL (usato per redirect dopo checkout)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Decision Gate (CI): il token si crea da Dashboard → Workspace → "Token CI (Decision Gate)" (un token per workspace).
# Non serve più DECERN_CI_TOKEN in .env.

# Supabase Service Role (solo server-side, es. Decision Gate e webhook RPC). Non esporre al client.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
