# Supabase
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Webhook Stripe: segreto condiviso con il DB (NON usare la service role).
# Dopo la migration 00014, in Supabase SQL Editor: select secret from app_webhook_secret;
# Copia il valore qui (una sola volta, puoi usare il SQL Editor con la service role per leggerlo).
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-from-db

# Stripe
# Chiavi: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID (NON Product ID): Stripe Dashboard → Prodotti → Crea prezzo per Team (49€/mese) e Business (99€/mese) → Copia gli ID (iniziano con price_)
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# App URL (usato per redirect dopo checkout)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Website URL (landing/pricing separati dal core app)
# NEXT_PUBLIC_WEBSITE_URL=https://decern.dev

# --- decern-gate CLI (solo CI, non servono per run dell'app) ---
# Usate dalla CLI in pipeline (GitHub Actions, GitLab, Jenkins). Vedi packages/decern-gate/README.md.
# DECERN_BASE_URL=https://your-app.vercel.app
# DECERN_CI_TOKEN=...   (da Dashboard → Workspace → Token CI; un token per workspace)
# DECERN_GATE_TIMEOUT_MS=5000
# Opzionali in CI: CI_BASE_SHA, CI_HEAD_SHA, CI_PR_TITLE, CI_PR_BODY, CI_COMMIT_MESSAGE

# Supabase Service Role (solo server-side, es. Decision Gate e webhook RPC). Non esporre al client.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Judge: massimo richieste per workspace per minuto (default 60). Evita abuso/costo LLM.
# JUDGE_RATE_LIMIT_PER_MINUTE=60

# Judge: massimo richieste per owner (account) per minuto, su tutti i workspace (default 120).
# JUDGE_RATE_LIMIT_PER_MINUTE_OWNER=120

# Judge usage billing (centesimi per 1M token). Default = 3× costo modello judge di fallback server-side.
# JUDGE_BILLING_INPUT_CENTS_PER_1M=840
# JUDGE_BILLING_OUTPUT_CENTS_PER_1M=4200

# Cron: segreto per chiamare POST /api/cron/bill-judge-usage (addebito mensile Judge su Stripe).
# CRON_SECRET=...

# GitHub OAuth (per collegare i repo ai progetti e salvare le decisioni come file ADR).
# Crea una GitHub OAuth App su https://github.com/settings/developers
# Homepage URL: http://localhost:3000 (o la tua URL di produzione)
# Authorization callback URL: http://localhost:3000/api/github/callback
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...
# GITHUB_WEBHOOK_SECRET=... (segreto per verificare i webhook push da GitHub)

# --- Private cloud package / license (Business self-host) ---
# Chiave licenza per abilitare il layer cloud in self-hosted.
# DECERN_LICENSE_KEY=lic_...
# Token npm (read-only) per installare il package privato @decernhq/cloud.
# NPM_TOKEN=...
# Chiave base64 (32 byte) per cifrare le API key BYO LLM salvate nel DB.
# Esempio generazione: openssl rand -base64 32
# DECERN_LLM_CREDENTIALS_ENCRYPTION_KEY=...
# Token GitHub (PAT fine-grained: Contents read) per clonare il repo protocol in build.
# DECERN_PROTOCOL_CLONE_TOKEN=github_pat_...
# URL HTTPS del repo protocol (obbligatorio se DECERN_PROTOCOL_CLONE_TOKEN è impostato).
# DECERN_PROTOCOL_REPO_URL=https://github.com/your-org/your-protocol-repo.git

# OpenAI (usato per AI decision generation e come fallback fair-use del Judge quando BYO LLM non e' fornito).
# OPEN_AI_API_KEY=sk-...
# OPEN_AI_MODEL=gpt-4o-mini
# AI decision generation fair-use mensile integrato (in centesimi): Free=100 (€1), Team=200 (€2), Business=400 (€4)
# AI_GENERATION_FAIR_USE_FREE_CAP_CENTS=100
# AI_GENERATION_FAIR_USE_TEAM_CAP_CENTS=200
# AI_GENERATION_FAIR_USE_BUSINESS_CAP_CENTS=400
# Pricing usato per stimare il consumo token (centesimi per 1M token)
# AI_GENERATION_BILLING_INPUT_CENTS_PER_1M=84
# AI_GENERATION_BILLING_OUTPUT_CENTS_PER_1M=420
# Cap fair-use mensile Judge fallback server-side (in centesimi): Team=900 (€9), Business=1900 (€19)
# JUDGE_FAIR_USE_TEAM_CAP_CENTS=900
# JUDGE_FAIR_USE_BUSINESS_CAP_CENTS=1900
