# ── Decern Self-Hosted — Environment Variables ──
# Copy this file to .env and fill in the values for your deployment.

# ── Required ──

# Supabase: create a project at https://supabase.com or self-host
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# After running migration 00014, get the webhook secret:
#   SELECT secret FROM app_webhook_secret;
SUPABASE_WEBHOOK_SECRET=

# The public URL where your instance will be accessible
NEXT_PUBLIC_APP_URL=https://decern.yourcompany.com

# Self-hosted mode (always true for Docker deployments — set automatically by the entrypoint)
NEXT_PUBLIC_SELF_HOSTED=true

# ── GitHub Integration (recommended) ──
# Create a GitHub OAuth App: https://github.com/settings/developers
# Homepage URL: https://decern.yourcompany.com
# Callback URL: https://decern.yourcompany.com/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# ── AI Features ──
# OpenAI key for AI decision generation and fair-use Judge fallback
OPEN_AI_API_KEY=sk-...
OPEN_AI_MODEL=gpt-4o-mini

# ── Optional ──
# JUDGE_RATE_LIMIT_PER_MINUTE=60
# JUDGE_RATE_LIMIT_PER_MINUTE_OWNER=120
# CRON_SECRET=your-cron-secret
